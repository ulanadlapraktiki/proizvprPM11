<Window x:Class="CartridgeAccounting.Windows.ReturnedCartridgesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CartridgeAccounting.Windows"
        mc:Ignorable="d"
        Title="Принятые картриджи" 
        Height="550" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Grid Margin="15">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="559*"/>
            <ColumnDefinition Width="411*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" 
                   Text="ПРИНЯТЫЕ КАРТРИДЖИ (из отделений и с заправки)" 
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Left"
                   Margin="0,14,0,41"
                   Foreground="#2C3E50"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,-3,0,18" Grid.Column="1">
            <Button x:Name="btnRefresh" Click="BtnRefresh_Click"
                    Background="#3498DB" Foreground="White"
                    Width="120" Height="35"
                    FontWeight="Bold"
                    Content="🔄 Обновить"/>
            <Button x:Name="btnReport" Click="BtnReport_Click"
                    Background="#9B59B6" Foreground="White"
                    Width="120" Height="37"
                    FontWeight="Bold"
                    Content="📊 Отчёт" RenderTransformOrigin="2.991,0.589"/>

            <Button x:Name="btnExport" Click="BtnExport_Click"
        Background="#9B59B6" Foreground="White"
        Width="140" Height="35" Margin="5"
        FontWeight="Bold" Content="📊 Экспорт в Excel"/>
        </StackPanel>

        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#BDC3C7" 
                BorderThickness="1" 
                CornerRadius="8"
                Padding="5" Grid.ColumnSpan="2">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 История приёма" 
                           FontSize="14" FontWeight="SemiBold"
                           Margin="5,5,0,5"/>
                <DataGrid x:Name="dgReturned" Grid.Row="1" 
                          AutoGenerateColumns="False"
                          AlternatingRowBackground="#F9F9F9"
                          IsReadOnly="True"
                          FontSize="13"
                          Margin="0,5,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Model ID" Binding="{Binding ModelID}" Width="80"/>
                        <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="110"/>
                        <DataGridTextColumn Header="Модель" Binding="{Binding ModelName}" Width="150"/>
                        <DataGridTextColumn Header="Тип операции" Binding="{Binding OperationName}" Width="150"/>
                        <DataGridTextColumn Header="Отделение / Источник" Binding="{Binding SourceName}" Width="180"/>
                        <DataGridTextColumn Header="Дата приёма" Binding="{Binding MovementDateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Принял" Binding="{Binding ReceivedByEmployee}" Width="130"/>
                        <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window> 