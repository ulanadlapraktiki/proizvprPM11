<Window x:Class="CartridgeAccounting.Windows.AddCartridgeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CartridgeAccounting.Windows"
        mc:Ignorable="d"
        Title="Добавление нового картриджа" 
        Height="500" Width="635"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0"
        ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление нового картриджа в систему"
                   FontSize="18" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <Grid Grid.Row="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Инвентарный номер:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtInventoryNumber" Grid.Column="1" 
                     Height="30" VerticalContentAlignment="Center" Margin="30,0,0,0"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Модель:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbModel" Grid.Column="1" Height="30"
                      DisplayMemberPath="DisplayText" 
                      SelectedValuePath="ModelID"
                      VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Дата покупки:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <DatePicker x:Name="dpPurchaseDate" Grid.Column="1" 
                        Height="30" VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Стоимость (руб.):" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtInitialCost" Grid.Column="1" 
                     Height="30" VerticalContentAlignment="Center"/>
        </Grid>

        <Grid Grid.Row="5" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Активен:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <CheckBox x:Name="chkIsActive" Grid.Column="1" 
                      IsChecked="True" VerticalAlignment="Center"/>
        </Grid>

        <StackPanel Grid.Row="6" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,30,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="120" Height="35" Margin="5"
                    FontWeight="Bold" Content="💾 Сохранить"/>
            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#E74C3C" Foreground="White"
                    Width="120" Height="35" Margin="5"
                    FontWeight="Bold" Content="❌ Отмена"/>
        </StackPanel>
    </Grid>
</Window>