<Window x:Class="CartridgeAccounting.Windows.ReferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CartridgeAccounting.Windows"
        mc:Ignorable="d"
        Title="Справочники системы" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Справочники"
                   FontSize="22" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>

        <TabControl Grid.Row="1" TabStripPlacement="Top">
            <TabItem Header="📦 Модели картриджей">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnAddModel" Click="BtnAddModel_Click"
                                Background="#27AE60" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="➕ Добавить"/>
                        <Button x:Name="btnEditModel" Click="BtnEditModel_Click"
                                Background="#3498DB" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="✏ Редактировать"/>
                        <Button x:Name="btnDeleteModel" Click="BtnDeleteModel_Click"
                                Background="#E74C3C" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="❌ Удалить"/>
                        <Button x:Name="btnRefreshModels" Click="BtnRefreshModels_Click"
                                Background="#95A5A6" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="🔄 Обновить"/>
                    </StackPanel>
                    <DataGrid x:Name="dgModels" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              AlternatingRowBackground="#F9F9F9"
                              Margin="0,5,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ModelID}" Width="50"/>
                            <DataGridTextColumn Header="Название модели" Binding="{Binding ModelName}" Width="200"/>
                            <DataGridTextColumn Header="Совместимые принтеры" Binding="{Binding CompatiblePrinters}" Width="250"/>
                            <DataGridTextColumn Header="Ресурс (стр)" Binding="{Binding StandardResourse}" Width="100"/>
                            <DataGridTextColumn Header="Тип" Binding="{Binding ColorType}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="🏢 Отделы">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnAddDepartment" Click="BtnAddDepartment_Click"
                                Background="#27AE60" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="➕ Добавить"/>
                        <Button x:Name="btnEditDepartment" Click="BtnEditDepartment_Click"
                                Background="#3498DB" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="✏ Редактировать"/>
                        <Button x:Name="btnDeleteDepartment" Click="BtnDeleteDepartment_Click"
                                Background="#E74C3C" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="❌ Удалить"/>
                        <Button x:Name="btnRefreshDepartments" Click="BtnRefreshDepartments_Click"
                                Background="#95A5A6" Foreground="White"
                                Width="100" Height="30" Margin="5"
                                Content="🔄 Обновить"/>
                    </StackPanel>
                    <DataGrid x:Name="dgDepartments" Grid.Row="1"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              AlternatingRowBackground="#F9F9F9"
                              Margin="0,5,0,0">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding DepartmentsID}" Width="50"/>
                            <DataGridTextColumn Header="Название отдела" Binding="{Binding DepartmentName}" Width="200"/>
                            <DataGridTextColumn Header="Здание" Binding="{Binding Building}" Width="150"/>
                            <DataGridTextColumn Header="Ответственный" Binding="{Binding ResponsiblePerson}" Width="200"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>