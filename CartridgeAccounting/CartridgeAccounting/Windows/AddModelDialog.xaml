<Window x:Class="CartridgeAccounting.Windows.AddModelDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CartridgeAccounting.Windows"
        mc:Ignorable="d"
        Title="Добавление новой модели" 
        Height="375" Width="504"
        WindowStartupLocation="CenterOwner"
        Background="#F0F0F0"
        ResizeMode="NoResize">

    <Grid Margin="15,15,15,-6">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Добавление новой модели картриджа"
                   FontSize="16" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,15"/>

        <Grid Grid.Row="1" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Название модели:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtModelName" Grid.Column="1" Height="30"/>
        </Grid>

        <Grid Grid.Row="2" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Совместимые принтеры:" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtCompatiblePrinters" Grid.Column="1" Height="30"/>
        </Grid>

        <Grid Grid.Row="3" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Ресурс (страниц):" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <TextBox x:Name="txtStandardResource" Grid.Column="1" Height="30"/>
        </Grid>

        <Grid Grid.Row="4" Margin="0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="120"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Тип (ЧБ/Цветной):" 
                       VerticalAlignment="Center" FontWeight="SemiBold"/>
            <ComboBox x:Name="cmbColorType" Grid.Column="1" Height="30">
                <ComboBoxItem Content="Чёрно-белый"/>
                <ComboBoxItem Content="Цветной"/>
            </ComboBox>
        </Grid>

        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
            <Button x:Name="btnSave" Click="BtnSave_Click"
                    Background="#27AE60" Foreground="White"
                    Width="100" Height="35" Margin="5"
                    Content="💾 Сохранить"/>
            <Button x:Name="btnCancel" Click="BtnCancel_Click"
                    Background="#E74C3C" Foreground="White"
                    Width="100" Height="35" Margin="5"
                    Content="❌ Отмена"/>
        </StackPanel>
    </Grid>
</Window>