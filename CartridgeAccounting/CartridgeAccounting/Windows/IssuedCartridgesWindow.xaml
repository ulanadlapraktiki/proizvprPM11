<Window x:Class="CartridgeAccounting.Windows.IssuedCartridgesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CartridgeAccounting.Windows"
        mc:Ignorable="d"
        Title="Выданные картриджи" 
        Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="ВЫДАННЫЕ КАРТРИДЖИ В ОТДЕЛЕНИЯ" 
                   FontSize="20" FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"
                   Foreground="#2C3E50"/>

        <Border Grid.Row="1" 
                Background="White" 
                BorderBrush="#BDC3C7" 
                BorderThickness="1" 
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="➕ Выдать картридж в отделение" 
                           FontSize="16" FontWeight="SemiBold"
                           Margin="0,0,0,10"
                           Foreground="#2980B9"/>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" 
                               Text="Картридж:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbCartridge" Grid.Row="0" Grid.Column="1" 
                              Margin="5" Height="30"
                              VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="0" Grid.Column="2" 
                               Text="Отделение:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <ComboBox x:Name="cmbDepartment" Grid.Row="0" Grid.Column="3" 
                              Margin="5" Height="30"
                              VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" 
                               Text="Выдал:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtIssuedBy" Grid.Row="1" Grid.Column="1" 
                             Margin="5" Height="30"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="1" Grid.Column="2" 
                               Text="Принял:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtReceivedBy" Grid.Row="1" Grid.Column="3" 
                             Margin="5" Height="30"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" 
                               Text="Дата выдачи:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <DatePicker x:Name="dpIssueDate" Grid.Row="2" Grid.Column="1" 
                                Margin="5" Height="30"
                                VerticalContentAlignment="Center"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" 
                               Text="Время:" 
                               VerticalAlignment="Center" Margin="5"/>
                    <TextBox x:Name="txtIssueTime" Grid.Row="2" Grid.Column="3" 
                             Text="12:00" Margin="5" Height="30"
                             VerticalContentAlignment="Center"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" 
                               Text="Примечание:" 
                               VerticalAlignment="Top" Margin="5,10,5,0"/>
                    <TextBox x:Name="txtNotes" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" 
                             Margin="5,5,5,5" Height="50"
                             TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
                </Grid>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <Button x:Name="btnIssue" Click="BtnIssue_Click"
                            Background="#27AE60" Foreground="White"
                            Width="150" Height="35" Margin="5"
                            FontWeight="Bold"
                            Content="✅ Выдать картридж"/>
                    <Button x:Name="btnRefresh" Click="BtnRefresh_Click"
                            Background="#3498DB" Foreground="White"
                            Width="120" Height="35" Margin="5"
                            FontWeight="Bold"
                            Content="🔄 Обновить"/>
                    <Button x:Name="btnExport" Click="BtnExport_Click"
        Background="#9B59B6" Foreground="White"
        Width="140" Height="35" Margin="5"
        FontWeight="Bold" Content="📊 Экспорт в Excel"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" 
                Background="White" 
                BorderBrush="#BDC3C7" 
                BorderThickness="1" 
                CornerRadius="8"
                Padding="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" Text="📋 История выдачи" 
                           FontSize="14" FontWeight="SemiBold"
                           Margin="5,5,0,5"/>
                <DataGrid x:Name="dgIssued" Grid.Row="1" 
                          AutoGenerateColumns="False"
                          AlternatingRowBackground="#F9F9F9"
                          IsReadOnly="True"
                          FontSize="13"
                          Margin="0,5,0,0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Инв. номер" Binding="{Binding InventoryNumber}" Width="110"/>
                        <DataGridTextColumn Header="Модель" Binding="{Binding ModelName}" Width="150"/>
                        <DataGridTextColumn Header="Отделение" Binding="{Binding DepartmentName}" Width="180"/>
                        <DataGridTextColumn Header="Дата выдачи" Binding="{Binding MovementDateTime, StringFormat='dd.MM.yyyy HH:mm'}" Width="150"/>
                        <DataGridTextColumn Header="Выдал" Binding="{Binding IssuedByEmployee}" Width="130"/>
                        <DataGridTextColumn Header="Принял" Binding="{Binding ReceivedByEmployee}" Width="130"/>
                        <DataGridTextColumn Header="Примечание" Binding="{Binding Notes}" Width="200"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>
    </Grid>
</Window>